# 시뮬레이션용 LLM provider 설정. 키/엔드포인트가 없으면 룰 기반 mock agent 로 동작합니다.
# (mock 은 흐름 검증용 — 실제 실험 데이터가 아닙니다.) 실제 값은 .env.local 에만 두고 커밋 금지.

# LLM_PROVIDER: "openai" | "anthropic" | "mock"  (unset/blank => mock)
LLM_PROVIDER=openai

# OpenAI 호환 백엔드 (본 연구는 로컬 Ollama 사용)
OPENAI_API_KEY=ollama                      # Ollama 는 키를 무시(아무 값). 호스티드면 실제 키.
OPENAI_BASE_URL=http://localhost:11434/v1  # 로컬 Ollama. (호스티드면 해당 엔드포인트)
OPENAI_MODEL=qwen2.5:32b

# (선택) Anthropic provider 를 쓸 경우에만 설정
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# agent 아키텍처: "generic"(baseline) | "uxagent"(persona+기억+반성+인터뷰)
AGENT_ARCH=generic
REFLECT_EVERY=4                            # uxagent reflection 주기(explore step)

# 재현/안정성
LLM_TEMPERATURE=0.2                        # action 단계 고정(변동은 persona 에서)
LLM_MAX_RETRIES=3
LLM_MAX_WAIT_MS=120000                     # 단일 재시도 대기 상한(초과 시 즉시 실패 → hang 방지)
LLM_ALLOW_MOCK_FALLBACK=false              # 기본 false: 실패 시 mock 으로 섞지 않고 중단(clean run 보존)

# 시뮬레이션이 구동할 대상 URL
SIM_BASE_URL=http://localhost:3000
