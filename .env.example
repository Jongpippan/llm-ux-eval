# LLM provider for simulation. If no key is set, the simulation falls back to the rule-based mock agent.
# 키가 없으면 mock agent(룰 기반)로 동작합니다. 실제 실험 데이터는 생성하지 않습니다.

# LLM_PROVIDER: "anthropic" | "openai" | "mock" (unset/blank => mock)
LLM_PROVIDER=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Base URL the simulation drives a browser against
SIM_BASE_URL=http://localhost:3000
